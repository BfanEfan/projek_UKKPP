<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Pahala Poin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-50 min-h-screen">
  <!-- HEADER -->
<div class="bg-red-900 text-white flex justify-between items-center px-8 py-4">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-white rounded-full overflow-hidden">
      <img src="/css/bpmlogo.jpeg" alt="icon" class="w-full h-full object-cover">
    </div>
    <h1 class="font-bold text-lg">SMK BINA PUTRA MANDIRI</h1>
  </div>
  <button class="bg-red-500 px-6 py-2 rounded-full hover:bg-red-600">
    Logout
  </button>
</div>
 
<div class="flex">
 
  <!-- SIDEBAR -->
  <div class="w-64 bg-gray-100 min-h-screen p-6">
    <a href="/dashboard"
      class="flex items-center gap-2 mb-6 font-bold text-[#332c2d]">
      <img src="/css/profil.png" alt="icon" class="w-7 h-7">
      E-DISIPLIN
    </a>

    <ul class="space-y-4">
      <li>
        <a href="/dashboard"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/rumah.png" alt="icon" class="w-5 h-5">
          Dashboard
        </a>
      </li>
      <li>
        <a href="/dasis"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/edu.png" alt="icon" class="w-5 h-5">
          Data Siswa
        </a>
      </li>
      <li>
        <a href="/pahalapoin"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/Update.png" alt="icon" class="w-5 h-5">
          Update pahala
        </a>
      </li>
    </ul>
  </div>
  <div class="max-w-6xl mx-auto py-10 px-6">
    
    <!-- Judul -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-green-700">Pahala dan Dosa Siswa</h1>
      <p class="text-gray-600 mt-2">Pengurangan poin pelanggaran karena melakukan kebaikan dan Penambahan poin 
        karena membuat dosa
      </p>
    </div>

    <!-- Card -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden">
      
      <table class="w-full text-left">
        <thead class="bg-green-600 text-white">
          <tr>
            <th class="px-4 py-3">NIPD</th>
            <th class="px-4 py-3">Nama Siswa</th>
            <th class="px-4 py-3">Total Poin</th>
            <th class="px-4 py-3 text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>

          <% if (siswa.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-6 text-gray-500">
                Tidak ada data siswa
              </td>
            </tr>
          <% } %>

          <% siswa.forEach(s => { %>
            <tr class="border-t hover:bg-green-50 transition">
              
              <td class="px-4 py-3"><%= s.nipd %></td>
              <td class="px-4 py-3 font-medium"><%= s.nama_siswa %></td>
              
              <td class="px-4 py-3">
                <span class="px-3 py-1 bg-red-100 text-red-600 rounded-full text-sm">
                  <%= s.total_poin %> poin
                </span>
              </td>

              <td class="px-4 py-3 text-center bg-gray-300">
                <form action="/pahalapoin/update/<%= s.nipd %>" method="POST">
                <input 
                  type="number" 
                  name="jumlah" 
                  min="1" 
                  value="1"
                >

                <button type="submit" name="aksi" value="tambah" class="bg-green-600 rounded-full text-lg">
                  Tambah
                </button>

                <button type="submit" name="aksi" value="kurang" class="bg-red-600 rounded-full text-lg">
                  Kurangi
                </button>

              </form>
              </td>

            </tr>
          <% }) %>

        </tbody>
      </table>
    </div>

  </div>

</body>
</html>