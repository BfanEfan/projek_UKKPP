<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Data Siswa</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

<!-- HEADER -->
<div class="bg-red-900 text-white flex justify-between items-center px-8 py-4">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-white rounded-full overflow-hidden">
      <img src="/css/bpmlogo.jpeg" class="w-full h-full object-cover">
    </div>
    <h1 class="font-bold text-lg">SMK BINA PUTRA MANDIRI</h1>
  </div>
  <!--log out-->
  <button 
  onclick="handleLogout()" 
  class="bg-red-500 px-6 py-2 rounded-full hover:bg-red-600 text-white transition-colors"
>
  Logout
</button>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function handleLogout() {
  Swal.fire({
    title: 'Konfirmasi Logout',
    text: "Apakah benar Anda ingin keluar?",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#ef4444', // Merah Tailwind
    cancelButtonColor: '#374151', // Abu-abu gelap
    confirmButtonText: 'Iya, Keluar',
    cancelButtonText: 'Batal',
    reverseButtons: true // Memposisikan tombol 'Iya' di kanan agar lebih user-friendly
  }).then((result) => {
    if (result.isConfirmed) {
      window.location.href = '/logout';
    }
  });
}
</script>
</div>

<div class="flex">

 <!-- SIDEBAR -->
  <div class="w-64 bg-gray-100 min-h-screen p-6">

    <ul class="space-y-4">
      <li>
        <a href="/dashboard"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/rumah.png" alt="icon" class="w-5 h-5">
          Dashboard
        </a>
      </li>
      <li>
        <a href="/dasis"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/edu.png" alt="icon" class="w-5 h-5">
          Data Siswa
        </a>
      </li>
      <li>
        <a href="/detailpel"
          class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold text-[#332c2d]">
          <img src="/css/detail.png" alt="icon" class="w-5 h-5">
          Detail pelanggaran
        </a>
      </li>
    </ul>
  </div>

<main class="flex-1 flex justify-center p-6">
<div class="w-full max-w-5xl">

<div class="flex justify-between items-center mb-4">
  <a href="/insertPel" class="bg-green-500 text-white px-4 py-2 rounded-lg">
    + Tambah Data
  </a>

</div>

<div class="overflow-x-auto mt-6">
<table class="min-w-full border bg-white rounded-lg shadow-lg">

<thead class="bg-blue-500 text-white">
<tr>
  <th class="px-6 py-3 border">No</th>
  <th class="px-6 py-3 border">Jenis</th>
  <th class="px-6 py-3 border">Deskripsi</th>
  <th class="px-6 py-3 border">Sanksi</th>
  <th class="px-6 py-3 border">Poin</th>
  <th class="px-6 py-3 border">Kode</th>
</tr>
</thead>

<tbody id="tableBody">
<% pelanggaran.forEach((p, index) => { %>
<tr class="text-center hover:bg-blue-100">
  <td class="border px-4 py-2"><%= index + 1 %></td>
  <td class="border px-4 py-2"><%= p.jenis %></td>
  <td class="border px-4 py-2 text-left"><%= p.deskripsi %></td>
  <td class="border px-4 py-2"><%= p.sanksi %></td>
  <td class="border px-4 py-2 text-green-600"><%= p.poin %></td>
  <td class="border px-4 py-2 text-red-700"><%= p.kode_pelanggaran %></td>
</tr>
<% }) %>
</tbody>

</table>
</div>

<!-- PAGINATION -->
<div class="flex justify-between items-center mt-4">
  <button onclick="prevPage()" class="bg-gray-400 text-white px-4 py-2 rounded">Prev</button>
  <span id="pageInfo" class="font-bold"></span>
  <button onclick="nextPage()" class="bg-blue-600 text-white px-4 py-2 rounded">Next</button>
</div>

</div>
</main>
</div>

<!-- SCRIPT PAGINATION -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const rowsPerPage = 10;
  let currentPage = 1;

  const table = document.getElementById("tableBody");
  const rows = table.getElementsByTagName("tr");
  const totalRows = rows.length;
  const totalPages = Math.ceil(totalRows / rowsPerPage);

  function showPage(page) {
    currentPage = page;

    for (let i = 0; i < totalRows; i++) {
      rows[i].style.display = "none";
    }

    const start = (page - 1) * rowsPerPage;
    const end = start + rowsPerPage;

    for (let i = start; i < end && i < totalRows; i++) {
      rows[i].style.display = "";
    }

    document.getElementById("pageInfo").innerText =
      "Halaman " + page + " dari " + totalPages;
  }

  window.nextPage = function () {
    if (currentPage < totalPages) {
      showPage(currentPage + 1);
    }
  };

  window.prevPage = function () {
    if (currentPage > 1) {
      showPage(currentPage - 1);
    }
  };

  showPage(1);
});
</script>

</body>
</html>