<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Data User - SMK BPM</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @media print {
      body * { visibility: hidden; }
      .print-area, .print-area * { visibility: visible; }
      .print-area { position: absolute; left: 0; top: 0; width: 100%; }
      .no-print { display: none !important; }
    }
  </style>
</head>

<body class="bg-gray-100">

<header class="bg-red-900 text-white flex justify-between items-center px-8 py-4 shadow no-print">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-white rounded-full overflow-hidden">
      <img src="/css/bpmlogo.jpeg" class="w-full h-full object-cover" alt="Logo">
    </div>
    <h1 class="font-bold text-lg uppercase">SMK BINA PUTRA MANDIRI</h1>
  </div>
  <div class="flex items-center gap-4">
    <button onclick="handleLogout()" class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded transition">Logout</button>
  </div>
</header>

<div class="flex">

<!-- SIDEBAR -->
    <aside class="w-64 bg-gray-100 min-h-screen p-6 shadow-sm">
      <ul class="space-y-4">

        <li>
          <a href="/dashboard" class="flex items-center gap-2 bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rumah.png" class="w-5 h-5">
            Dashboard
          </a>
        </li>

        <li>
          <a href="/dasis" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/edu.png" class="w-5 h-5">
            Data Siswa
          </a>
        </li>

        <li>
          <a href="/datse" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/user.png" class="w-5 h-5">
            Data User
          </a>
        </li>

        <li>
          <a href="/detailpel" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/detail.png" class="w-5 h-5">
            Tata Tertib sekolah
          </a>
        </li>

        <li>
          <a href="/rekap" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rekapp.png" class="w-5 h-5">
            Rekap pelanggaran siswa
          </a>
        </li>

      </ul>
    </aside>

  <main class="flex-1 p-8">
    
    <div class="flex justify-between items-center mb-6 no-print">
      <div>
        <h2 class="text-2xl font-bold text-gray-800">Manajemen Data User</h2>
        <p class="text-gray-500">Kelola akun administrator dan guru</p>
      </div>
      <div class="flex gap-2">
        <a href="/register" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded shadow transition">
          + Tambah User
        </a>
      </div>
    </div>

    <div class="print-area bg-white rounded-lg shadow-md overflow-hidden">
      
      <div class="hidden print:block text-center border-b pb-4 mb-6 p-6">
        <h2 class="text-xl font-bold uppercase">Daftar Pengguna Sistem</h2>
        <p>SMK Bina Putra Mandiri</p>
      </div>

      <div class="overflow-x-auto bg-white rounded-lg shadow border border-gray-200">
        <table class="w-full text-left border-collapse">
            <thead>
            <tr class="bg-gray-800 text-gray-100">
                <th class="px-6 py-4 border-b font-bold uppercase text-xs w-16 text-center">No</th>
                <th class="px-6 py-4 border-b font-bold uppercase text-xs">ID Admin</th>
                <th class="px-6 py-4 border-b font-bold uppercase text-xs">Username</th>
                <th class="px-6 py-4 border-b font-bold uppercase text-xs text-center">Role</th>
                <th class="px-6 py-4 border-b font-bold uppercase text-xs text-center no-print">Aksi</th>
            </tr>
            </thead>
            <tbody id="tableBody" class="divide-y divide-gray-200">
            <% if (users.length === 0) { %>
                <tr>
                <td colspan="5" class="text-center py-12 text-gray-400 italic bg-gray-50">
                    <p>Belum ada data user terdaftar.</p>
                </td>
                </tr>
            <% } %>

            <% users.forEach((u, i) => { %>
                <tr class="hover:bg-gray-50 transition-colors duration-200">
                <td class="px-6 py-4 text-center text-sm text-gray-500"><%= i + 1 %></td>
                <td class="px-6 py-4">
                    <span class="font-mono text-sm text-gray-600">
                    <%= u.id_admin %>
                    </span>
                </td>
                <td class="px-6 py-4">
                    <div class="font-semibold text-gray-800"><%= u.username %></div>
                </td>
                <td class="px-6 py-4 text-center">
                    <span class="inline-block px-4 py-1 text-xs font-bold uppercase tracking-widest
                    <%= u.role === 'admin' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>">
                    <%= u.role %>
                    </span>
                </td>
                <td class="px-6 py-4 no-print text-center">
                    <div class="flex justify-center items-center">
                    <form action="/users/delete/<%= u.id_admin %>" method="POST" onsubmit="return confirm('Hapus user <%= u.username %>?')">
                        <button type="submit" class="flex items-center gap-2 text-red-600 hover:text-red-800 font-bold text-xs uppercase transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3m4 0h5M4 7h16" />
                        </svg>
                        Hapus
                        </button>
                    </form>
                    </div>
                </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
        </div>
    </div>

  </main>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const rowsPerPage = 10;
  let currentPage = 1;

  const table = document.getElementById("tableBody");
  const rows = table.getElementsByTagName("tr");
  const totalRows = rows.length;
  const totalPages = Math.ceil(totalRows / rowsPerPage);

  function showPage(page) {
    if (totalPages === 0) return;
    currentPage = page;

    for (let i = 0; i < totalRows; i++) {
      rows[i].style.display = "none";
    }

    const start = (page - 1) * rowsPerPage;
    const end = start + rowsPerPage;

    for (let i = start; i < end && i < totalRows; i++) {
      rows[i].style.display = "";
    }

    document.getElementById("pageInfo").innerText = 
      `Menampilkan ${start + 1} sampai ${Math.min(end, totalRows)} dari ${totalRows} user`;
  }

  window.nextPage = function () { if (currentPage < totalPages) showPage(currentPage + 1); };
  window.prevPage = function () { if (currentPage > 1) showPage(currentPage - 1); };

  showPage(1);
});

function handleLogout() {
  if(confirm("Apakah Anda yakin ingin keluar?")) {
    window.location.href = "/logout";
  }
}
</script>

</body>
</html>