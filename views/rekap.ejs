<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rekap Pelanggaran</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
  </style>
</head>

<body class="bg-gray-200 text-[#332c2d]">

  <!-- HEADER -->
  <header class="bg-red-900 text-white flex justify-between items-center px-8 py-4 shadow relative">

    <!-- LOGO -->
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-white rounded-full overflow-hidden">
        <img src="/css/bpmlogo.jpeg" class="w-full h-full object-cover">
      </div>
      <h1 class="font-bold text-lg uppercase">SMK BINA PUTRA MANDIRI</h1>
    </div>

    <!-- KANAN -->
    <div class="flex items-center gap-4">

      <!-- PROFIL -->
      <div class="relative">
  <button onclick="toggleDropdown()" class="flex items-center gap-3 focus:outline-none">
    
    <div class="w-10 h-10 rounded-full border-2 border-white bg-blue-600 flex items-center justify-center text-white font-bold uppercase shadow-sm">
      <%= (locals.user && locals.user.role === 'bk') ? 'B' : 'A' %>
    </div>

    <span class="font-semibold">
      <%= (locals.user && locals.user.role === 'bk') ? 'bk' : 'Admin' %>
    </span>
    
  </button>

        <!-- DROPDOWN -->
        <div id="dropdownMenu" class="hidden absolute right-0 mt-3 w-48 bg-white text-black rounded-lg shadow-lg overflow-hidden">
          <a href="#" class="block px-4 py-2 hover:bg-gray-200">Profil Saya</a>
          <button onclick="handleLogout()" class="w-full text-left px-4 py-2 hover:bg-gray-200">
            Logout
          </button>
        </div>
      </div>

    </div>
  </header>

  <div class="flex">

    <!-- SIDEBAR -->
    <aside class="w-64 bg-gray-100 min-h-screen p-6 shadow-sm">
      <ul class="space-y-4">

        <li>
          <a href="/dashboard" class="flex items-center gap-2 bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rumah.png" class="w-5 h-5">
            Dashboard
          </a>
        </li>

        <li>
          <a href="/dasis" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/edu.png" class="w-5 h-5">
            Data Siswa
          </a>
        </li>

        <li>
          <a href="/detailpel" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/detail.png" class="w-5 h-5">
            Tata Tertib sekolah
          </a>
        </li>

        <li>
          <a href="/rekap" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rekapp.png" class="w-5 h-5">
            Rekap pelanggaran siswa
          </a>
        </li>

      </ul>
    </aside>

    <!-- MAIN -->
    <main class="flex-1 p-8 overflow-auto">

      <h2 class="text-2xl font-bold mb-2">Rekap Pelanggaran Siswa</h2>
      <p class="text-gray-600 mb-6">Data riwayat pelanggaran siswa</p>

      <!-- TABEL -->
      <div class="bg-white rounded-xl shadow overflow-auto">

        <table class="w-full text-left text-sm">

          <!-- HEADER -->
          <thead class="bg-gray-100 text-gray-700">
            <tr>
              <th class="p-3">No</th>
              <th class="p-3">Nama</th>
              <th class="p-3">Kelas</th>
              <th class="p-3">Jurusan</th>
              <th class="p-3">Kode</th>
              <th class="p-3">Pelanggaran</th>
              <th class="p-3">Poin</th>
              <th class="p-3">Tanggal</th>
              <th class="p-3">Input By</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody>

            <% if (data && data.length > 0) { %>

              <% data.forEach((item, index) => { %>

                <tr class="border-t hover:bg-gray-50">

                  <td class="p-3"><%= index + 1 %></td>

                  <td class="p-3 font-semibold">
                    <%= item.nama_siswa %>
                  </td>

                  <td class="p-3">
                    <%= item.kelas %>
                  </td>

                  <td class="p-3">
                    <%= item.nama_jurusan %>
                  </td>

                  <td class="p-3 text-blue-600 font-bold">
                    <%= item.kode_pelanggaran %>
                  </td>

                  <td class="p-3 text-red-500">
                    <%= item.deskripsi %>
                  </td>

                  <td class="p-3 font-bold text-amber-600">
                    <%= item.poin %>
                  </td>

                  <td class="p-3">
                    <%= new Date(item.tanggal).toLocaleDateString('id-ID', {
                    weekday: 'long',
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                    }) %>
                  </td>

                  <td class="p-3 text-sm">
                    <span class="font-semibold"><%= item.input_by %></span>
                    <br>
                    <span class="text-gray-500 text-xs">(<%= item.role %>)</span>
                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="9" class="p-5 text-center text-gray-500">
                  Tidak ada data pelanggaran
                </td>
              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </main>

  </div>

</body>
</html>