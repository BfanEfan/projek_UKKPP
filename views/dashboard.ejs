<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard SMK BPM</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
    @media print {
      body * { visibility: hidden; }
      .print-area, .print-area * { visibility: visible; }
      .print-area { position: absolute; left: 0; top: 0; width: 100%; }
      .no-print { display: none !important; }
    }
  </style>
</head>

<body class="bg-gray-100">

<header class="bg-red-900 text-white flex justify-between items-center px-8 py-4 shadow no-print">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-white rounded-full overflow-hidden">
      <img src="/css/bpmlogo.jpeg" class="w-full h-full object-cover" alt="Logo">
    </div>
    <h1 class="font-bold text-lg uppercase">SMK BINA PUTRA MANDIRI</h1>
  </div>
  <div class="flex items-center gap-4">
    <button onclick="handleLogout()" class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded transition">Logout</button>
  </div>
</header>

  <div class="flex">

      <!-- SIDEBAR -->
    <aside class="w-64 bg-gray-100 min-h-screen p-6 shadow-sm">
      <ul class="space-y-4">

        <li>
          <a href="/dashboard" class="flex items-center gap-2 bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rumah.png" class="w-5 h-5">
            Dashboard
          </a>
        </li>

        <li>
          <a href="/dasis" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/edu.png" class="w-5 h-5">
            Data Siswa
          </a>
        </li>

        <li>
          <a href="/datse" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/user.png" class="w-5 h-5">
            Data User
          </a>
        </li>

        <li>
          <a href="/detailpel" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/detail.png" class="w-5 h-5">
            Tata Tertib sekolah
          </a>
        </li>

        <li>
          <a href="/rekap" class="flex items-center gap-2 hover:bg-gray-300 p-2 rounded font-bold">
            <img src="/css/rekapp.png" class="w-5 h-5">
            Rekap pelanggaran siswa
          </a>
        </li>

      </ul>
    </aside>

    <!-- MAIN -->
    <main class="flex-1 p-8">

      <div class="mb-6">
        <h2 class="text-2xl font-bold mb-1">Overview Sekolah</h2>
        <p class="text-gray-600">Kelola kedisiplinan siswa dengan mudah</p>
      </div>

      <!-- CARD -->
      <div class="grid grid-cols-3 gap-6 mb-8">

        <!-- TOTAL SISWA -->
        <div class="bg-white p-6 rounded-xl shadow flex items-center gap-4">
          <img src="/css/siswas.png" class="w-12 h-12">
          <div>
            <p class="text-black font-bold">Total Siswa</p>
            <h3 class="text-3xl font-bold text-black"><%= totalSiswa %></h3>
          </div>
        </div>

        <!-- MELANGGAR -->
        <div class="bg-white p-6 rounded-xl shadow flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center text-amber-600 text-4xl">
            ⚠️
          </div>
          <div>
            <p class="text-black font-bold">Siswa Melanggar</p>
            <h3 class="text-3xl font-bold text-amber-600"><%= topel %></h3>
          </div>
        </div>

        <!-- MERAH -->
        <div class="bg-white p-6 rounded-xl shadow flex items-center gap-4">
          <img src="/css/api.png" class="w-12 h-12">
          <div>
            <p class="text-black font-bold">Daftar Merah</p>
            <h3 class="text-3xl font-bold text-red-500"><%= tori %></h3>
          </div>
        </div>

      </div>

      <!-- WELCOME -->
      <div class="bg-white p-8 rounded-xl shadow">
        <h3 class="text-xl font-bold mb-3">Selamat Datang 👋</h3>
        <p class="text-gray-500">
          Website ini digunakan untuk memantau dan mencatat poin pelanggaran siswa. <br>
          Silakan pilih menu di sebelah kiri untuk mulai mengelola data.
        </p>
      </div>

    </main>
  </div>

  <!-- SCRIPT -->
  <script>
    function toggleDropdown() {
      document.getElementById("dropdownMenu").classList.toggle("hidden");
    }

    function handleLogout() {
      Swal.fire({
        title: 'Konfirmasi Logout',
        text: "Apakah benar Anda ingin keluar?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#b91c1c',
        cancelButtonColor: '#374151',
        confirmButtonText: 'Iya, Keluar',
        cancelButtonText: 'Batal',
        reverseButtons: true
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/logout';
        }
      });
    }

    // Klik luar nutup dropdown
    window.onclick = function(e) {
      if (!e.target.closest('.relative')) {
        document.getElementById("dropdownMenu").classList.add("hidden");
      }
    }
  </script>

</body>
</html>