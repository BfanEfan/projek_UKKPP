<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Tambah Data Siswa</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex justify-center items-center min-h-screen">

<div class="bg-white p-6 rounded-lg shadow-lg w-full max-w-md">
    <h2 class="text-2xl font-bold text-center mb-5">Tambah Data Siswa</h2>
<form action="/insertdata" method="POST" class="space-y-4">

    <div>
        <label class="block font-semibold mb-1">NIPD</label>
        <input type="text" name="nipd" id="nipd" required
            class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-400">
    </div>

    <div>
        <label class="block font-semibold mb-1">Nama</label>
        <input type="text" name="nama_siswa" id="nama_siswa" required
            class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-400">
    </div>

    <div>
        <label class="block font-semibold mb-1">Kelas</label>
        <input type="text" name="kelas_siswa" id="kelas_siswa" required
            class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-400">
    </div>

    <div>
        <label class="block font-semibold mb-1">Jurusan</label>
        
        <select name="jurusan" 
            class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-400"
            required>
            
            <option value="">-- Pilih Jurusan --</option>

            <% jurusan.forEach(function(j) { %>
                <option value="<%= j.jurusan %>">
                    <%= j.jurusan %>
                </option>
            <% }) %>

        </select>
    </div>

    <div>
        <label class="block font-semibold mb-1">Kode pelanggaran</label>
        <select name="kode_pelanggaran">
            <% pelanggaran.forEach(function(data){ %>
                <option value="<%= data.kode_pelanggaran %>">
                    <%= data.kode_pelanggaran %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="flex gap-2">
        <button type="submit"
            class="bg-blue-500 hover:bg-blue-600 text-white rounded-md w-[80px] h-[40px]">
            Simpan
        </button>

        <a href="/dashboard"
            class="w-full text-center bg-gray-400 text-white py-2 rounded-md hover:bg-gray-500 transition">
            Kembali
        </a>
    </div>

</form>
</div>
</body>
</html>